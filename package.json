{
  "name": "board-game-library",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:integration": "playwright test",
    "test:e2e": "npm run test:e2e:setup && node scripts/run-e2e.js",
    "test:e2e:setup": "docker compose -f docker-compose.test.yml up -d --build --wait",
    "test:e2e:teardown": "docker compose -f docker-compose.test.yml down -v",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.59.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.11.0",
    "@types/ws": "^8.5.0",
    "drizzle-kit": "^0.31.10",
    "svelte": "^5.0.0",
    "svelte-check": "^4.4.8",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.45.2",
    "fast-check": "^4.8.0",
    "papaparse": "^5.5.3",
    "pg": "^8.13.0",
    "svelte-hot-french-toast": "^4.0.0",
    "ws": "^8.20.1"
  },
  "type": "module"
}
